.container-last-msg {{ display: flex; justify-content: space-between; padding: 10px 12px; background: rgba(0, 0, 0, 0.2); border-radius: 8px; font-size: 12px; }}
.msg-label {{ color: var(--text-secondary); }}
.msg-time {{ color: var(--accent-cyan); font-weight: 600; }}

/* Alerts Panel */
.alerts-container {{ max-height: 600px; overflow-y: auto; }}
.alert-item {{ display: flex; align-items: center; gap: 10px; padding: 12px 15px; background: rgba(0, 0, 0, 0.2); border-radius: 10px; margin-bottom: 8px; border-left: 3px solid; }}
.alert-warning {{ border-left-color: var(--accent-yellow); background: rgba(255, 170, 0, 0.08); }}
.alert-error {{ border-left-color: var(--accent-red); background: rgba(255, 68, 68, 0.08); }}
.alert-icon {{ font-size: 16px; }}
.alert-time {{ font-size: 12px; color: var(--text-secondary); min-width: 85px; }}
.alert-msg {{ font-size: 13px; color: var(--text-primary); flex: 1; }}
.alerts-empty {{ text-align: center; color: var(--accent-green); padding: 30px; font-size: 14px; }}

/* Stats */
.stats-grid {{ display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 20px; }}
.stat-card {{ background: rgba(0, 0, 0, 0.3); border-radius: 16px; padding: 20px; text-align: center; }}
.stat-value {{ font-size: 36px; font-weight: 700; margin-bottom: 8px; }}
.stat-value.cpu {{ color: var(--accent-red); }}
.stat-value.mem {{ color: var(--accent-cyan); }}
.stat-label {{ font-size: 13px; color: var(--text-secondary); }}
.stat-chart {{ margin-top: 12px; }}

/* Logs */
.logs-container {{ max-height: 300px; overflow-y: auto; }}
.log-entry {{ padding: 10px 12px; background: rgba(0, 0, 0, 0.2); border-radius: 8px; margin-bottom: 8px; font-family: 'JetBrains Mono', monospace; font-size: 12px; border-left: 3px solid transparent; }}
.log-info {{ border-left-color: var(--accent-cyan); }}
.log-warn {{ border-left-color: var(--accent-yellow); background: rgba(255, 170, 0, 0.05); }}
.log-error {{ border-left-color: var(--accent-red); background: rgba(255, 68, 68, 0.05); }}

/* Tasks */
.tasks-grid {{ display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; margin-bottom: 24px; }}
.task-card {{ background: rgba(0, 0, 0, 0.3); border-radius: 16px; padding: 20px; border: 1px solid var(--border-color); transition: all 0.3s ease; }}
.task-card:hover {{ transform: translateY(-2px); background: rgba(0, 0, 0, 0.4); }}
.task-header {{ display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }}
.task-name {{ font-size: 16px; font-weight: 600; color: var(--text-primary); }}
.task-badge {{ padding: 4px 10px; border-radius: 12px; font-size: 11px; font-weight: 600; }}
.task-badge-busy {{ background: rgba(255, 170, 0, 0.2); color: #ffaa00; }}
.task-badge-idle {{ background: rgba(0, 255, 136, 0.2); color: #00ff88; }}
.task-role {{ font-size: 13px; color: var(--text-secondary); margin-bottom: 12px; }}
.task-last {{ display: flex; justify-content: space-between; padding: 10px 12px; background: rgba(0, 0, 0, 0.2); border-radius: 8px; font-size: 12px; margin-bottom: 8px; }}
.task-last-label {{ color: var(--text-secondary); }}
.task-last-time {{ color: var(--accent-cyan); font-weight: 600; }}
.task-last-summary {{ font-size: 11px; color: var(--text-secondary); padding: 8px 12px; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }}
.task-no-recent {{ font-size: 12px; color: var(--text-secondary); text-align: center; padding: 15px; }}
.task-history-section {{ margin-top: 20px; }}
.section-subtitle {{ font-size: 14px; color: var(--text-secondary); margin-bottom: 12px; font-weight: 500; }}
.task-history-list {{ max-height: 250px; overflow-y: auto; }}
.task-history-item {{ display: flex; align-items: center; gap: 12px; padding: 10px 12px; background: rgba(0, 0, 0, 0.2); border-radius: 8px; margin-bottom: 6px; font-size: 12px; }}
.th-time {{ color: var(--text-secondary); min-width: 90px; }}
.th-worker {{ color: var(--accent-cyan); min-width: 70px; font-weight: 600; }}
.th-type {{ flex: 1; color: var(--text-primary); }}
.th-status {{ padding: 3px 10px; border-radius: 8px; font-size: 11px; font-weight: 600; }}
.th-status-done {{ background: rgba(0, 255, 136, 0.2); color: #00ff88; }}
.th-status-pending {{ background: rgba(255, 170, 0, 0.2); color: #ffaa00; }}
.task-history-empty {{ text-align: center; color: var(--text-secondary); padding: 20px; font-size: 13px; }}

/* Create Task Form */
.create-task-section {{ background: rgba(0, 0, 0, 0.2); border-radius: 12px; padding: 16px; margin-top: 16px; }}
.task-form-row {{ display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }}
.task-form-select {{ background: rgba(0, 0, 0, 0.3); border: 1px solid var(--border-color); color: var(--text-primary); padding: 10px 14px; border-radius: 8px; font-size: 13px; min-width: 140px; cursor: pointer; }}
.task-form-select:hover {{ border-color: var(--accent-cyan); }}
.task-form-input {{ flex: 1; min-width: 200px; background: rgba(0, 0, 0, 0.3); border: 1px solid var(--border-color); color: var(--text-primary); padding: 10px 14px; border-radius: 8px; font-size: 13px; }}
.task-form-input:focus {{ outline: none; border-color: var(--accent-cyan); }}
.task-create-btn {{ background: linear-gradient(135deg, var(--accent-cyan), var(--accent-green)); border: none; color: #000; padding: 10px 20px; border-radius: 8px; font-weight: 600; font-size: 13px; cursor: pointer; transition: all 0.3s ease; }}
.task-create-btn:hover {{ transform: translateY(-2px); box-shadow: 0 4px 12px rgba(0, 217, 255, 0.4); }}
.task-create-btn:active {{ transform: translateY(0); }}

/* Refresh Button */
.refresh-btn {{ background: rgba(255, 255, 255, 0.1); border: 1px solid var(--border-color); color: var(--text-primary); padding: 6px 12px; border-radius: 8px; font-size: 12px; cursor: pointer; margin-left: auto; transition: all 0.3s ease; }}
.refresh-btn:hover {{ background: rgba(255, 255, 255, 0.15); border-color: var(--accent-cyan); }}

/* Scrollbar */
::-webkit-scrollbar {{ width: 6px; height: 6px; }}
::-webkit-scrollbar-track {{ background: rgba(0, 0, 0, 0.2); }}
::-webkit-scrollbar-thumb {{ background: rgba(255, 255, 255, 0.1); border-radius: 3px; }}
</style>
</head>
<body>
<div class="container">
<header>
    <h1>🚀 OpenClaw 企业监控中心</h1>
    <p class="subtitle">
        <span><span class="live-dot"></span>实时监控</span>
        <span>· 更新时间：{now}</span>
        <span>· 5 秒自动刷新</span>
    </p>
</header>

<div class="main-grid">
<div class="main-content">
    <section class="section">
        <div class="section-title"><span class="section-title-icon">📊</span>系统资源</div>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-value cpu">{stats["cpu"]}%</div>
                <div class="stat-label">CPU 使用率</div>
                <div class="stat-chart">{cpu_chart}</div>
            </div>
            <div class="stat-card">
                <div class="stat-value mem">{stats["mem_percent"]:.0f}%</div>
                <div class="stat-label">内存 {stats["mem_used"]}/{stats["mem_total"]} MB</div>
                <div class="stat-chart">{mem_chart}</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" style="color:var(--accent-green);font-size:28px">{len([c for c in containers if c.get("status")=="running"])}/{len(containers)}</div>
                <div class="stat-label">容器运行中</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" style="color:var(--accent-yellow);font-size:28px">{len(alerts_list)}</div>
                <div class="stat-label">活跃告警</div>
            </div>
        </div>
        <div style="text-align:center;color:var(--text-secondary);font-size:13px">
            系统运行：{uptime_display} · 负载：{load_display}
        </div>
    </section>

    <section class="section">
        <div class="section-title"><span class="section-title-icon">🐳</span>容器状态总览</div>
        <div class="containers-grid">
            {containers_html}
        </div>
    </section>

    <section class="section">
        <div class="section-title"><span class="section-title-icon">📝</span>实时日志</div>
        <div class="logs-container">{logs_html}</div>
    </section>

    <section class="section">
        <div class="section-title">
            <span class="section-title-icon">📋</span>任务队列管理
            <button class="refresh-btn" onclick="refreshTasks()" title="刷新任务状态">🔄 刷新</button>
        </div>
        <div class="tasks-grid" id="tasks-grid">
            {''.join([f'''
            <div class="task-card">
                <div class="task-header">
                    <span class="task-name">{t["name"]}</span>
                    <span class="task-badge {"task-badge-busy" if t["pending"] > 0 else "task-badge-idle"}">{t["pending"]} 待处理</span>
                </div>
                <div class="task-role">{t["role"]}</div>
                {f'<div class="task-last"><span class="task-last-label">最近任务</span><span class="task-last-time">{t["last_task"]["time"]}</span></div><div class="task-last-summary">{html_escape(t["last_task"]["summary"])}</div>' if t["last_task"] else '<div class="task-no-recent">暂无任务记录</div>'}
            </div>
            ''' for t in tasks])}
        </div>

        <!-- 创建任务表单 -->
        <div class="create-task-section">
            <div class="section-subtitle">➕ 创建新任务</div>
            <div class="task-form-row">
                <select id="task-worker" class="task-form-select">
                    <option value="tech">CTO (技术员)</option>
                    <option value="ops">运营官</option>
                    <option value="image">设计师</option>
                    <option value="naming">南南 (命名官)</option>
                </select>
                <select id="task-type" class="task-form-select">
                    <option value="code">代码开发</option>
                    <option value="review">代码审查</option>
                    <option value="content">内容运营</option>
                    <option value="design">设计</option>
                    <option value="naming">命名/SEO</option>
                    <option value="debug">调试</option>
                    <option value="general">通用任务</option>
                </select>
                <input type="text" id="task-content" class="task-form-input" placeholder="输入任务描述..." onkeypress="if(event.key==='Enter')createTask()">
                <button class="task-create-btn" onclick="createTask()">发送任务</button>
            </div>
        </div>

        <div class="task-history-section">
            <div class="section-subtitle">任务历史</div>
            <div class="task-history-list" id="task-history-list">
                {f''.join([f'<div class="task-history-item"><span class="th-time">{th["time"]}</span><span class="th-worker">{th["worker"]}</span><span class="th-type">{th["type"]}</span><span class="th-status {"th-status-done" if th["status"] == "completed" else "th-status-pending"}">{th["status"]}</span></div>' for th in task_history_list[-10:]]) if task_history_list else '<div class="task-history-empty">暂无任务历史记录</div>'}
            </div>
        </div>
    </section>
</div>

<div class="side-panel">
    <section class="section">
        <div class="section-title"><span class="section-title-icon">🔔</span>异常告警</div>
        <div class="alerts-container">
            {alerts_html}
        </div>
    </section>
</div>
</div>

<footer style="text-align:center;padding:20px;color:var(--text-secondary);font-size:12px;border-top:1px solid var(--border-color);margin-top:30px;">
    OpenClaw 企业监控系统 v4.0 · 南朝译 AI 团队
</footer>
</div>
<script>
function createTask() {{
    const worker = document.getElementById('task-worker').value;
    const type = document.getElementById('task-type').value;
    const content = document.getElementById('task-content').value.trim();
    if (!content) {{ alert('请输入任务描述'); return; }}
    fetch('/api/task/create', {{
        method: 'POST',
        headers: {{'Content-Type': 'application/json'}},
        body: JSON.stringify({{worker, type, content}})
    }})
    .then(r => r.json())
    .then(data => {{
        if (data.success) {{
            alert('任务已创建');
            document.getElementById('task-content').value = '';
            refreshTasks();
        }} else {{ alert('创建失败：' + data.message); }}
    }})
    .catch(e => alert('错误：' + e));
}}

function refreshTasks() {{
    fetch('/api/tasks')
    .then(r => r.json())
    .then(data => {{
        const grid = document.getElementById('tasks-grid');
        if (grid && data.tasks) {{
            grid.innerHTML = data.tasks.map(t => {{
                const badgeClass = t.pending > 0 ? 'task-badge-busy' : 'task-badge-idle';
                const lastTaskHtml = t.last_task ?
                    `<div class="task-last"><span class="task-last-label">最近任务</span><span class="task-last-time">${{t.last_task.time}}</span></div><div class="task-last-summary">${{t.last_task.summary}}</div>` :
                    '<div class="task-no-recent">暂无任务记录</div>';
                return `<div class="task-card"><div class="task-header"><span class="task-name">${{t.name}}</span><span class="task-badge ${{badgeClass}}">${{t.pending}} 待处理</span></div><div class="task-role">${{t.role}}</div>${{lastTaskHtml}}</div>`;
            }}).join('');
        }}
        const historyList = document.getElementById('task-history-list');
        if (historyList && data.history && data.history.length > 0) {{
            historyList.innerHTML = data.history.slice(-10).map(th =>
                `<div class="task-history-item"><span class="th-time">${{th.time}}</span><span class="th-worker">${{th.worker}}</span><span class="th-type">${{th.type}}</span><span class="th-status">${{th.status}}</span></div>`
            ).join('');
        }} else if (historyList) {{
            historyList.innerHTML = '<div class="task-history-empty">暂无任务历史记录</div>';
        }}
    }})
    .catch(e => console.error('刷新失败:', e));
}}

document.addEventListener('DOMContentLoaded', refreshTasks);
</script>
</body>
</html>'''

class Handler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path == '/api/tasks':
            # 获取任务列表 API
            self.send_response(200)
            self.send_header('Content-type', 'application/json; charset=utf-8')
            self.end_headers()
            tasks = get_worker_tasks()
            history = get_task_history()
            response = json.dumps({'tasks': tasks, 'history': history}, ensure_ascii=False)
            self.wfile.write(response.encode('utf-8'))
        elif self.path == '/api/workers':
            # 获取 Worker 列表 API
            self.send_response(200)
            self.send_header('Content-type', 'application/json; charset=utf-8')
            self.end_headers()
            workers = [
                {'id': 'tech', 'name': 'CTO', 'role': '技术员'},
                {'id': 'ops', 'name': '运营官', 'role': '运营官'},
                {'id': 'image', 'name': '设计师', 'role': '设计师'},
                {'id': 'naming', 'name': '南南', 'role': '命名官'}
            ]
            self.wfile.write(json.dumps(workers, ensure_ascii=False).encode('utf-8'))
        else:
            # 主页面
            self.send_response(200)
            self.send_header('Content-type', 'text/html; charset=utf-8')
            self.end_headers()
            self.wfile.write(get_html().encode('utf-8'))

    def do_POST(self):
        if self.path.startswith('/api/task/create'):
            # 创建任务 API
            content_length = int(self.headers.get('Content-Length', 0))
            post_data = self.rfile.read(content_length)
            try:
                data = json.loads(post_data.decode('utf-8'))
                worker = data.get('worker', 'tech')
                task_type = data.get('type', 'general')
                content = data.get('content', '')

                # 记录任务到历史
                add_task_to_history(worker, task_type, 'pending', content)

                # 尝试调用 openclaw CLI 创建任务（如果可用）
                result = run_cmd(f"docker exec openclaw-{worker} openclaw task create --type {task_type} --content '{content}' 2>/dev/null || echo 'CLI_NOT_AVAILABLE'")

                self.send_response(200)
                self.send_header('Content-type', 'application/json; charset=utf-8')
                self.end_headers()
                response = json.dumps({
                    'success': True,
                    'message': '任务已创建' if result != 'CLI_NOT_AVAILABLE' else '任务已记录（CLI 不可用）',
                    'worker': worker,
                    'task_type': task_type
                }, ensure_ascii=False)
                self.wfile.write(response.encode('utf-8'))
            except Exception as e:
                self.send_response(400)
                self.send_header('Content-type', 'application/json; charset=utf-8')
                self.end_headers()
                response = json.dumps({'success': False, 'message': str(e)}, ensure_ascii=False)
                self.wfile.write(response.encode('utf-8'))
        else:
            self.send_response(404)
            self.end_headers()

    def log_message(self, format, *args):
        pass

if __name__ == "__main__":
    socketserver.TCPServer.allow_reuse_address = True
    with socketserver.TCPServer(("", PORT), Handler) as httpd:
        print(f"监控网页已启动：http://0.0.0.0:{PORT}")
        httpd.serve_forever()
