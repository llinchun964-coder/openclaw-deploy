# OpenClaw 路径配置（南朝译多实例架构）
OPENCLAW_HOME=/root/.openclaw/master
OPENCLAW_CONFIG_PATH=/root/.openclaw/master/openclaw.json
OPENCLAW_WORKSPACE_ROOT=/root/.openclaw/workspace
OPENCLAW_AGENT_ROOT=/root/.openclaw/agents

# Redis 连接（用量追踪）
