    containers = get_all_containers()
    alerts_list = get_recent_alerts()

    # 系统统计
    stats = {"cpu": "0", "mem_percent": 0, "mem_used": "0", "mem_total": "0"}
    cpu = run_cmd("top -bn1 | grep 'Cpu(s)' | awk '{print $2}' | cut -d'%' -f1")
    stats["cpu"] = cpu or "0"
    mem_info = run_cmd("free -m | awk 'NR==2{printf \"%d %d %.0f\", $3, $2, $3/$2*100}'")
    if mem_info:
        parts = mem_info.split()
        if len(parts) >= 3:
            stats["mem_used"], stats["mem_total"], stats["mem_percent"] = parts[0], parts[1], float(parts[2])

    # 保存历史
    history.append({"time": now, "cpu": float(stats["cpu"]), "mem": stats["mem_percent"]})
    save_data()

    # 检查告警
    check_alerts(containers)

    # 容器卡片
    containers_html = ""
    for c in containers:
        is_running = c.get("status") == "running"
        is_a2a_ok = c.get("a2a_status", "online") == "online"

        # 状态颜色和图标
        if c.get("is_redis"):
            status_icon = "🟢" if is_running else "🔴"
            status_text = "运行中" if is_running else "已停止"
            color = "#00d9ff"
        elif c.get("is_pm2"):
            status_icon = "🟢" if is_running else "🔴"
            status_text = "运行中" if is_running else "已停止"
            color = "#ffd93d"
        else:
            if is_running and is_a2a_ok:
                status_icon = "🟢"
                status_text = "运行中"
                color = "#00ff88"
            elif is_running and not is_a2a_ok:
                status_icon = "🟡"
                status_text = "失联"
                color = "#ffaa00"
            else:
                status_icon = "🔴"
                status_text = "异常"
                color = "#ff4444"

        # 最后消息时间
        last_msg = c.get("last_msg", "")
        last_msg_display = ""
        if last_msg:
            try:
                msg_time = datetime.strptime(last_msg, '%Y-%m-%dT%H:%M:%S')
                diff = (datetime.now() - msg_time).seconds
                if diff < 60:
                    last_msg_display = f"{diff}秒前"
                elif diff < 3600:
                    last_msg_display = f"{diff//60}分钟前"
                else:
                    last_msg_display = f"{diff//3600}小时前"
            except:
                last_msg_display = last_msg

        mem_display = f"{c.get('mem', 0):.1f}{c.get('mem_unit', 'MB')}"

        containers_html += f'''
        <div class="container-card" style="border-left:4px solid {color}">
            <div class="container-header">
                <div class="container-status-icon">{status_icon}</div>
                <div class="container-basic-info">
                    <div class="container-name">{c['name']}</div>
                    <div class="container-role">{c.get('role', '')}</div>
                </div>
                <div class="container-status-badge" style="background:{color}22;color:{color}">{status_text}</div>
            </div>
            <div class="container-stats">
                <div class="stat-item">
                    <span class="stat-label">运行时长</span>
                    <span class="stat-value-small">{c.get('uptime', '未知')}</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">CPU</span>
                    <span class="stat-value-small" style="color:{'#00ff88' if c.get('cpu', 0) < 50 else '#ffaa00' if c.get('cpu', 0) < 80 else '#ff4444'}">{c.get('cpu', 0):.1f}%</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">内存</span>
                    <span class="stat-value-small" style="color:#00d9ff">{mem_display}</span>
                </div>
            </div>
            {f'<div class="container-last-msg"><span class="msg-label">最后消息</span><span class="msg-time">{last_msg_display}</span></div>' if last_msg and not c.get('is_redis') and not c.get('is_pm2') else ''}
        </div>'''

    # 告警列表
    alerts_html = ""
    if alerts_list:
        for a in reversed(alerts_list[-15:]):
            alert_class = "alert-error" if a["level"] == "error" else "alert-warning"
            alert_icon = "🔴" if a["level"] == "error" else "🟡"
            alerts_html += f'''
            <div class="alert-item {alert_class}">
                <span class="alert-icon">{alert_icon}</span>
                <span class="alert-time">{a["time"]}</span>
                <span class="alert-msg">{html_escape(a["msg"])}</span>
            </div>'''
    else:
        alerts_html = '<div class="alerts-empty">✓ 暂无异常</div>'

    # 日志
    logs = get_recent_logs()
    logs_html = ""
    for log in logs[-15:]:
        log_class = "log-error" if "error" in log.lower() or "Error" in log else "log-warn" if "circuit" in log or "timeout" in log else "log-info"
        logs_html += f'<div class="log-entry {log_class}">{log}</div>'

    # 图表
    cpu_chart = generate_svg_chart([h["cpu"] for h in history[-30:]], 180, 50, "#ff6b6b")
    mem_chart = generate_svg_chart([h["mem"] for h in history[-30:]], 180, 50, "#00d9ff")

    uptime_result = run_cmd("uptime -p")
    uptime_display = uptime_result.replace("up ", "") if uptime_result else "未知"
    load_result = run_cmd("uptime | awk -F'load average:' '{print $2}' | awk -F',' '{print $1}'")
    load_display = load_result.strip() if load_result else "0"

    return f'''<!DOCTYPE html>
