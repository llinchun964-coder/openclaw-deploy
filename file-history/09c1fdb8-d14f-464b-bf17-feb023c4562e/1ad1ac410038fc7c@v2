#!/bin/bash
set -e

# Openclaw 还原脚本
# 用法: ./restore.sh [--force] [--skip-images]

BACKUP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$BACKUP_DIR"

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# 默认配置
FORCE=false
SKIP_IMAGES=false

# 解析参数
while [[ $# -gt 0 ]]; do
    case $1 in
        -f|--force)
            FORCE=true
            shift
            ;;
        -s|--skip-images)
            SKIP_IMAGES=true
            shift
            ;;
        *)
            log_error "Unknown option: $1"
            exit 1
            ;;
    esac
done

log_info "开始还原 Openclaw..."
log_info "备份目录: $BACKUP_DIR"

# 检查备份文件
if [ ! -f "data/openclaw-config.tar.gz" ]; then
    log_error "未找到备份文件 data/openclaw-config.tar.gz"
    exit 1
fi

# ==========================================
# 1. 检查 Docker 是否安装
# ==========================================
log_info "检查 Docker..."
if ! command -v docker &> /dev/null; then
    log_error "Docker 未安装，请先安装 Docker"
    exit 1
fi
if ! command -v docker-compose &> /dev/null && ! docker compose version &> /dev/null; then
    log_warn "Docker Compose 未找到，可能需要安装"
fi
log_info "  ✓ Docker 就绪"

# ==========================================
# 2. 停止现有容器
# ==========================================
log_info "检查现有容器..."
if [ "$FORCE" = true ]; then
    log_warn "强制模式：停止并删除现有 openclaw 容器"
    docker ps -a --format '{{.Names}}' | grep -E 'openclaw' | xargs -r docker stop 2>/dev/null || true
    docker ps -a --format '{{.Names}}' | grep -E 'openclaw' | xargs -r docker rm 2>/dev/null || true
else
    if docker ps --format '{{.Names}}' | grep -q 'openclaw'; then
        log_error "发现正在运行的 openclaw 容器！"
        log_info "使用 --force 参数强制覆盖，或手动停止容器"
        exit 1
    fi
fi

# ==========================================
# 3. 导入 Docker 镜像
# ==========================================
if [ "$SKIP_IMAGES" = false ] && [ -d "images" ] && [ "$(ls -A images/ 2>/dev/null)" ]; then
    log_info "导入 Docker 镜像..."
    for tar_file in images/*.tar; do
        if [ -f "$tar_file" ]; then
            log_info "  导入: $tar_file"
            docker load -i "$tar_file"
        fi
    done
    log_info "  ✓ 镜像导入完成"
elif [ "$SKIP_IMAGES" = false ] && [ -f "data/images-list.txt" ]; then
    log_info "拉取 Docker 镜像..."
    log_warn "镜像文件不存在，尝试从列表拉取（可能需要重新构建）"
    cat data/images-list.txt | while read -r image; do
        if [ -n "$image" ]; then
            log_info "  拉取: $image"
            docker pull "$image" 2>/dev/null || log_warn "    拉取失败: $image"
        fi
    done
else
    log_info "跳过镜像导入"
fi

# ==========================================
# 4. 还原 Openclaw 配置
# ==========================================
log_info "还原 Openclaw 配置..."
if [ -d "/root/.openclaw" ]; then
    if [ "$FORCE" = true ]; then
        mv "/root/.openclaw" "/root/.openclaw.backup.$(date '+%Y%m%d_%H%M%S')"
        log_info "  已备份现有配置"
    else
        log_error "/root/.openclaw 已存在！"
        log_info "使用 --force 参数强制覆盖"
        exit 1
    fi
fi

tar -xzf "data/openclaw-config.tar.gz" -C "/root"
log_info "  ✓ 配置已还原"

# ==========================================
# 5. 还原环境变量
# ==========================================
log_info "配置环境变量..."
if [ -f ".env.backup" ]; then
    log_warn "发现 .env.backup，请手动配置以下文件："
    log_info "  1. 复制 .env.example 为 /root/.openclaw/.env"
    log_info "  2. 参考 .env.backup 填入真实的 API 密钥"
else
    if [ ! -f "/root/.openclaw/.env" ] && [ -f ".env.example" ]; then
        cp ".env.example" "/root/.openclaw/.env"
        log_warn "已创建 .env 文件，请编辑填入真实密钥"
    fi
fi

# ==========================================
# 6. 还原 Redis 数据
# ==========================================
if [ -f "data/redis-dump.rdb" ]; then
    log_info "还原 Redis 数据..."
    if [ ! "$(docker ps -a --format '{{.Names}}' | grep -E 'redis')" ]; then
        log_warn "Redis 容器未启动，跳过数据还原"
        log_info "提示：启动容器后手动导入 Redis 数据"
    else
        docker cp "data/redis-dump.rdb" openclaw-redis-shared:/data/dump.rdb 2>/dev/null || true
        docker restart openclaw-redis-shared 2>/dev/null || true
        log_info "  ✓ Redis 数据已还原"
    fi
fi

# ==========================================
# 7. 还原启动脚本
# ==========================================
log_info "还原启动脚本..."
if [ -d "scripts" ]; then
    cp scripts/*.sh /root/ 2>/dev/null || true
    chmod +x /root/*.sh 2>/dev/null || true
    log_info "  ✓ 启动脚本已还原"
fi

# ==========================================
# 8. 启动服务
# ==========================================
log_info ""
log_info "=========================================="
log_info "  还原完成！"
log_info "=========================================="
log_info ""
log_info "下一步操作："
log_info "  1. 检查 /root/.openclaw/.env 配置"
log_info "  2. 进入 docker 目录并启动容器："
log_info "     cd /root/openclaw-docker"
log_info "     docker-compose up -d"
log_info "  3. 或者使用启动脚本："
log_info "     cd /root"
log_info "     ./start-all-final.sh"
log_info ""
