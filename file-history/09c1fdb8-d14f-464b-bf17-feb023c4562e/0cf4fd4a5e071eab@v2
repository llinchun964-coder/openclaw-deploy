#!/bin/bash
set -e

# Openclaw 备份脚本
# 用法: ./backup.sh [--full|--quick] [-m "commit message"]

BACKUP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$BACKUP_DIR"

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# 默认配置
FULL_BACKUP=false
QUICK_BACKUP=false
COMMIT_MESSAGE="Backup at $(date '+%Y-%m-%d %H:%M:%S')"

# 解析参数
while [[ $# -gt 0 ]]; do
    case $1 in
        -f|--full)
            FULL_BACKUP=true
            shift
            ;;
        -q|--quick)
            QUICK_BACKUP=true
            shift
            ;;
        -m|--message)
            COMMIT_MESSAGE="$2"
            shift 2
            ;;
        *)
            log_error "Unknown option: $1"
            exit 1
            ;;
    esac
done

log_info "开始备份 Openclaw..."
log_info "备份目录: $BACKUP_DIR"

# 创建目录结构
mkdir -p config/credentials
mkdir -p scripts
mkdir -p data
mkdir -p images

# ==========================================
# 1. 备份 Docker Compose 配置
# ==========================================
log_info "备份 Docker 配置..."
if [ -f "/root/.openclaw/docker-compose.yml" ]; then
    cp "/root/.openclaw/docker-compose.yml" "$BACKUP_DIR/"
    log_info "  ✓ docker-compose.yml 已复制"
elif [ -f "/root/openclaw-docker/docker-compose.yml" ]; then
    cp "/root/openclaw-docker/docker-compose.yml" "$BACKUP_DIR/"
    log_info "  ✓ docker-compose.yml 已复制"
else
    log_warn "  未找到 docker-compose.yml"
fi

# ==========================================
# 2. 备份 Openclaw 配置（排除大文件）
# ==========================================
log_info "备份 Openclaw 配置..."
if [ -d "/root/.openclaw" ]; then
    # 使用 tar 打包，排除大文件和临时文件
    tar -czf "$BACKUP_DIR/data/openclaw-config.tar.gz" \
        -C "/root" \
        --exclude=".openclaw/cache" \
        --exclude=".openclaw/.npm" \
        --exclude=".openclaw/node_modules" \
        --exclude=".openclaw/a2a-tasks" \
        --exclude="*.log" \
        .openclaw
    log_info "  ✓ .openclaw 已打包"

    # 单独备份 openclaw.json
    if [ -f "/root/.openclaw/openclaw.json" ]; then
        cp "/root/.openclaw/openclaw.json" "$BACKUP_DIR/config/"
        log_info "  ✓ openclaw.json 已复制"
    fi

    # 备份环境变量模板
    if [ -f "/root/.openclaw/.env" ]; then
        cp "/root/.openclaw/.env" "$BACKUP_DIR/.env.backup"
        log_info "  ✓ .env 已备份到 .env.backup"
    fi
fi

# ==========================================
# 3. 备份启动脚本
# ==========================================
log_info "备份启动脚本..."
cp /root/start-all-final.sh "$BACKUP_DIR/scripts/" 2>/dev/null || true
cp /root/start-all-openclaw.sh "$BACKUP_DIR/scripts/" 2>/dev/null || true
log_info "  ✓ 启动脚本已备份"

# ==========================================
# 4. 导出 Redis 数据
# ==========================================
log_info "导出 Redis 数据..."
if docker ps --format '{{.Names}}' | grep -q "openclaw-redis-shared"; then
    docker exec openclaw-redis-shared redis-cli BGSAVE >/dev/null 2>&1
    sleep 2
    docker cp openclaw-redis-shared:/data/dump.rdb "$BACKUP_DIR/data/redis-dump.rdb" 2>/dev/null || true
    if [ -f "$BACKUP_DIR/data/redis-dump.rdb" ]; then
        log_info "  ✓ Redis 数据已导出"
    fi
else
    log_warn "  Redis 容器未运行，跳过"
fi

# ==========================================
# 5. 完整备份：保存 Docker 镜像
# ==========================================
if [ "$FULL_BACKUP" = true ]; then
    log_info "完整备份模式：保存 Docker 镜像..."
    for image in $(docker images --format '{{.Repository}}:{{.Tag}}' | grep -E 'openclaw|redis' | grep -v '<none>'); do
        safe_name=$(echo "$image" | tr '/' '_' | tr ':' '_')
        log_info "  保存镜像: $image"
        docker save -o "$BACKUP_DIR/images/${safe_name}.tar" "$image" 2>/dev/null || log_warn "    保存失败，跳过"
    done
else
    log_info "记录 Docker 镜像版本..."
    docker images --format '{{.Repository}}:{{.Tag}}' | grep -E 'openclaw|redis' | grep -v '<none>' > "$BACKUP_DIR/data/images-list.txt"
    log_info "  ✓ 镜像列表已保存"
fi

# ==========================================
# 6. Git 提交
# ==========================================
log_info "准备 Git 提交..."
if [ -d ".git" ]; then
    git add .
    git commit -m "$COMMIT_MESSAGE" 2>/dev/null || log_warn "没有变更需要提交"
    log_info "  ✓ Git 提交完成"
else
    log_warn "  不是 Git 仓库，跳过提交"
    log_info "  提示: 运行 'git init' 初始化仓库"
fi

log_info ""
log_info "=========================================="
log_info "  备份完成！"
log_info "=========================================="
log_info ""
log_info "下一步操作："
log_info "  1. 检查 $BACKUP_DIR/.env.backup 文件，敏感信息不要提交"
log_info "  2. 运行 'git push' 推送到 GitHub"
log_info ""
