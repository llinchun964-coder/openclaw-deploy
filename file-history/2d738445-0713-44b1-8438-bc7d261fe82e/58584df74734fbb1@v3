def run_cmd(cmd):
    try:
        result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=5)
        return result.stdout.strip()
    except:
        return ""

def clean_ansi(text):
    """清除 ANSI 颜色代码"""
    ansi_escape = re.compile(r'\x1B(?:[@-Z\\-_]|\[[0-?]*[ -/]*[@-~])')
    return ansi_escape.sub('', text)

def get_workers():
    workers = [
        ("技术员", 18811, "👨‍💻"),
        ("运营官", 18813, "📝"),
        ("设计师", 18815, "🎨"),
        ("南南", 18817, "🤖"),
    ]
    result = []
    for name, port, icon in workers:
        http_code = run_cmd(f"curl -s -o /dev/null -w '%{{http_code}}' http://127.0.0.1:{port}/.well-known/agent-card.json 2>/dev/null")
        latency = run_cmd(f"curl -s -o /dev/null -w '%{{time_total}}' http://127.0.0.1:{port}/.well-known/agent-card.json 2>/dev/null")
        ok = http_code == "200"
        result.append({"name": name, "ok": ok, "latency": latency if latency else "0", "icon": icon})
    return result

def get_activity():
    logs = run_cmd("pm2 logs master-nanchaoyi --lines 5 --nostream 2>&1 | grep -E 'dispatch|Feishu'")
    logs = clean_ansi(logs)
    return [l.strip() for l in logs.split('\n') if l.strip()][-5:]

def get_system():
    containers = run_cmd("docker ps --filter 'name=openclaw-' --format '{{.Names}}: {{.Status}}' | grep -v redis")
    circuit_check = run_cmd("pm2 logs master-nanchaoyi --lines 5 --nostream 2>&1 | grep -c 'circuit.open' || echo 0")
    circuit = "正常" if circuit_check.strip() == "0" else "有熔断"
    tasks = run_cmd("for w in tech ops image naming; do docker exec openclaw-$w ls /root/.openclaw/a2a-tasks/ 2>/dev/null | wc -l | tr '\\n' ' '; done")
    if not tasks.strip():
        tasks = "0 0 0 0"

    circuit_html = f'<span style="color:#ff4444">⚠ 有熔断</span>' if circuit != "正常" else '<span style="color:#00ff88">✓ 正常</span>'

    return f"""
    <div>🐳 容器：{containers.replace(chr(10), '<br>')}</div>
    <div style="margin-top:8px">⚡ 熔断器：{circuit_html}</div>
    <div style="margin-top:8px">📋 任务队列：{tasks}</div>
    """

class Handler(http.server.SimpleHTTPRequestHandler):
    def do_GET(self):
        if self.path == '/api':
            data = {
                "workers": get_workers(),
                "activity": get_activity(),
                "system": get_system()
            }
            self.send_response(200)
            self.send_header('Content-type', 'application/json; charset=utf-8')
            self.end_headers()
            self.wfile.write(json.dumps(data, ensure_ascii=False).encode('utf-8'))
        elif self.path == '/' or self.path == '/index.html':
            self.send_response(200)
            self.send_header('Content-type', 'text/html; charset=utf-8')
            self.end_headers()
            self.wfile.write(HTML.encode('utf-8'))
        else:
            super().do_GET()

    def log_message(self, format, *args):
        pass  # 禁用日志输出

if __name__ == "__main__":
    socketserver.TCPServer.allow_reuse_address = True
    with socketserver.TCPServer(("", PORT), Handler) as httpd:
        print(f"📊 监控网页已启动：http://0.0.0.0:{PORT}")
        print(f"本地访问：http://localhost:{PORT}")
        print(f"远程访问：http://服务器 IP:{PORT}")
        httpd.serve_forever()
