    .container {{ padding: 15px; }}
    h1 {{ font-size: 26px; }}
    .workers-grid {{ grid-template-columns: 1fr; }}
    .stats-grid {{ grid-template-columns: repeat(2, 1fr); }}
    .data-row {{ flex-direction: column; gap: 15px; align-items: flex-start; }}
}}
</style>
</head>
<body>
<div class="container">
<header>
    <div class="title-wrap">
        <h1>🚀 OpenClaw 监控中心</h1>
    </div>
    <p class="subtitle">
        <span class="live-indicator"><span class="live-dot"></span>实时监控</span>
        <span>·</span>
        <span>更新时间：{now}</span>
        <span>·</span>
        <span>5 秒自动刷新</span>
    </p>
</header>

<section class="workers-grid">
{workers_html}
</section>

<section class="section">
    <div class="section-header">
        <div class="section-title"><span class="section-title-icon">📊</span>系统资源</div>
    </div>
    <div class="stats-grid">
        <div class="stat-card cpu">
            <div class="stat-value">{stats["cpu"]}%</div>
            <div class="stat-label">CPU 使用率</div>
            <div class="stat-chart">{cpu_chart}</div>
        </div>
        <div class="stat-card mem">
            <div class="stat-value">{stats["mem_percent"]:.0f}%</div>
            <div class="stat-label">内存 {stats["mem_used"]}/{stats["mem_total"]} MB</div>
            <div class="stat-chart">{mem_chart}</div>
        </div>
        <div class="stat-card workers">
            <div class="stat-value">{sum(1 for w in workers if w["ok"])}/4</div>
            <div class="stat-label">在线 Workers</div>
            <div class="stat-chart">{workers_chart}</div>
        </div>
        <div class="stat-card uptime">
            <div class="stat-value" style="font-size:28px">{uptime_display}</div>
            <div class="stat-label">运行时间</div>
            <div style="font-size:12px;color:var(--text-secondary);margin-top:8px">负载：{load_display}</div>
        </div>
    </div>

    <div class="circuit-wrap" style="border-left-color:{circuit_color}">
        <span class="circuit-icon" style="filter:drop-shadow(0 0 10px {circuit_color}66)">{circuit_icon}</span>
        <div class="circuit-info">
            <div class="circuit-label">熔断器状态</div>
            <div class="circuit-value" style="color:{circuit_color}">{'所有熔断器正常' if not circuit["open"] else f"发现 {circuit['count']} 个熔断"}</div>
        </div>
    </div>
</section>

<section class="section">
    <div class="section-header">
        <div class="section-title"><span class="section-title-icon">🐳</span>容器监控</div>
    </div>
    {containers_html if containers_html else '<div style="text-align:center;color:var(--text-secondary);padding:30px">无容器运行</div>'}
</section>

<section class="section">
    <div class="section-header">
        <div class="section-title"><span class="section-title-icon">📋</span>任务队列</div>
    </div>
    {tasks_html if tasks_html else '<div style="text-align:center;color:var(--text-secondary);padding:30px">无任务</div>'}
</section>

<section class="section">
    <div class="section-header">
        <div class="section-title"><span class="section-title-icon">📝</span>实时日志</div>
    </div>
    <div class="log-container">
    {logs_html}
    </div>
</section>

<footer>
    OpenClaw 监控系统 v3.0 Ultimate · 南朝译 AI 团队
</footer>
</div>
</body>
</html>'''

class Handler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        self.send_response(200)
        self.send_header('Content-type', 'text/html; charset=utf-8')
        self.end_headers()
        self.wfile.write(get_html().encode('utf-8'))
    def log_message(self, format, *args):
        pass

if __name__ == "__main__":
    socketserver.TCPServer.allow_reuse_address = True
    with socketserver.TCPServer(("", PORT), Handler) as httpd:
        print(f"监控网页已启动：http://0.0.0.0:{PORT}")
        httpd.serve_forever()
