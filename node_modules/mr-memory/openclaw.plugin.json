{
  "id": "mr-memory",
  "uiHints": {
    "key": {
      "label": "Memory Key",
      "sensitive": true,
      "placeholder": "mk_xxx",
      "help": "Your MemoryRouter API key (get one at memoryrouter.ai)"
    },
    "endpoint": {
      "label": "API Endpoint",
      "placeholder": "https://api.memoryrouter.ai/v1",
      "advanced": true,
      "help": "Override for self-hosted MemoryRouter"
    },
    "density": {
      "label": "Memory Density",
      "placeholder": "high",
      "advanced": true,
      "help": "Amount of memory to inject: low (40), high (80), xhigh (160)"
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "key": {
        "type": "string",
        "pattern": "^mk[_-]"
      },
      "endpoint": {
        "type": "string"
      },
      "density": {
        "type": "string",
        "enum": ["low", "high", "xhigh"]
      },
      "logging": {
        "type": "boolean"
      },
      "mode": {
        "type": "string",
        "enum": ["relay", "proxy"]
      },
      "embeddings": {
        "type": "string",
        "enum": ["bge", "qwen"],
        "description": "Embedding model: bge (1024d, default) or qwen (4096d)"
      }
    },
    "required": []
  }
}
